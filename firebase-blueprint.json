{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "accidentalPreference": { "type": "string", "enum": ["mixed", "sharps", "flats"] }
      },
      "required": ["uid", "email", "displayName", "accidentalPreference"]
    },
    "songs": {
      "title": "Song",
      "description": "Song lyrics and chords",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["chord", "lyric"] },
        "key": { "type": "string" },
        "originalKey": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "content", "type", "key", "originalKey"]
    },
    "setlists": {
      "title": "Setlist",
      "description": "Collection of songs for a service",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "songs": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "date", "songs"]
    },
    "notices": {
      "title": "Notice",
      "description": "Announcements and scales",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string", "enum": ["aviso", "escala"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "content", "date", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/songs/{songId}": {
      "schema": "songs",
      "description": "Song documents"
    },
    "/setlists/{setlistId}": {
      "schema": "setlists",
      "description": "Setlist documents"
    },
    "/notices/{noticeId}": {
      "schema": "notices",
      "description": "Notice documents"
    }
  }
}
